# Database Configuration
# PostgreSQL connection string
# Format: postgres://username:password@host:port/database?sslmode=disable
DATABASE_URL=postgres://postgres:postgres@localhost:5432/goster_iot?sslmode=disable

# Web Server Configuration
WEB_HTTP_ADDR=:8080
API_CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# API Server Configuration
API_TCP_ADDR=:8081
API_READ_TIMEOUT=60s
API_REGISTER_ACK_GRACE_DELAY=100ms

# Authentication Configuration
AUTHBOSS_ROOT_URL=http://localhost:8080
AUTH_COOKIE_SECURE=false

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Session Configuration
AUTH_SESSION_COOKIE_MAX_AGE_SECONDS=0
AUTH_REMEMBER_COOKIE_MAX_AGE_SECONDS=2592000

# Captcha Configuration (optional)
# Supported: cloudflare, hcaptcha
CAPTCHA_PROVIDER=
CF_SITE_KEY=
CF_SECRET_KEY=
CAPTCHA_VERIFY_TIMEOUT=5s

# Device Manager Configuration
DM_QUEUE_CAPACITY=100
DM_HEARTBEAT_DEADLINE=60s

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=text
LOG_ADD_SOURCE=false
LOG_SERVICE=goster-iot
LOG_ENV=dev
APP_ENV=dev
