# Database
DB_DRIVER=postgres
DB_DSN=postgres://postgres:postgres@postgres:5432/goster_iot?sslmode=disable

# Web/Auth
AUTHBOSS_ROOT_URL=http://localhost:8080
AUTH_COOKIE_SECURE=false
API_CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Captcha / Cloudflare Turnstile
CAPTCHA_PROVIDER=
CF_SITE_KEY=
CF_SECRET_KEY=

# Logging
LOG_LEVEL=info
LOG_FORMAT=text
APP_ENV=dev
