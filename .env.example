# Copy this file to `.env` when running docker compose from repo root.
#
#   cp .env.example .env
#   docker compose -f docker-compose.example.yml up -d

# Docker Compose port bindings
CORE_HTTP_BIND=0.0.0.0
CORE_HTTP_PORT=8080
INGRESS_TCP_BIND=0.0.0.0
INGRESS_TCP_PORT=8081
INGRESS_MQTT_BIND=0.0.0.0
INGRESS_MQTT_PORT=1883

# Database inside the core container. The compose file maps ./data/core -> /data.
DB_DRIVER=sqlite
DB_PATH=/data/data.db
DB_DSN=

# Web/Auth
AUTHBOSS_ROOT_URL=http://localhost:8080
AUTH_COOKIE_SECURE=false
API_CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Captcha / Cloudflare Turnstile
CAPTCHA_PROVIDER=
CF_SITE_KEY=
CF_SECRET_KEY=

# Logging
LOG_LEVEL=info
LOG_FORMAT=text
APP_ENV=dev

# Core <-> protocol-ingress
PROTOCOL_INGRESS_TOKEN=change-me
PROTOCOL_INGRESS_CUSTOM_TCP_ENABLED=true

# MQTT embedded broker in protocol-ingress. Keep disabled unless devices need MQTT.
PROTOCOL_INGRESS_MQTT_ENABLED=false
